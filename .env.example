# Public
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/5490000000000
# Default online meeting link used until a specialist-specific link exists.
ONLINE_CONSULTATION_URL=https://meet.google.com/xxx-xxxx-xxx

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=your-mercadopago-access-token
MERCADOPAGO_WEBHOOK_SECRET=your-mercadopago-webhook-secret

# Google Calendar
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must match the redirect URI configured in Google Cloud OAuth.
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/especialista/google/callback

# Email
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=LUMEN <contacto@your-domain.com>
EMAIL_REPLY_TO=contacto@your-domain.com
CONTACT_EMAIL=contacto@your-domain.com

# Cron
# Shared secret required by scheduled internal API routes.
CRON_SECRET=your-cron-secret

# Banco
NEXT_PUBLIC_BANK_ALIAS=lumen.pagos
NEXT_PUBLIC_BANK_CBU=0000000000000000000000
